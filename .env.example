PORT=3000
HOST=127.0.0.1
APP_BASE_URL=http://localhost:3000

# 新建 App 的 appId（作为 client_id 使用）
SECONDME_CLIENT_ID=8614994a-75b1-4394-a765-ba9b321a553a

# 可留空。留空时程序会读取 ~/.secondme/client_secret
SECONDME_CLIENT_SECRET=

SECONDME_REDIRECT_URI=http://localhost:3000/api/auth/callback
SECONDME_SCOPE=userinfo
SECONDME_CALLBACK_PATH=/api/auth/callback
SECONDME_REDIRECT_HOST_ALLOWLIST=localhost:3000,127.0.0.1:3000

SECONDME_OAUTH_URL=https://go.second.me/oauth/
SECONDME_API_BASE_URL=https://api.mindverse.com/gate/lab
SECONDME_TOKEN_ENDPOINT=https://api.mindverse.com/gate/lab/api/oauth/token/code
SECONDME_USERINFO_ENDPOINT=https://api.mindverse.com/gate/lab/api/secondme/user/info

# MCP / Integration
MCP_AUTH_MODE=bearer_token
MCP_TIMEOUT_MS=12000
SECONDME_SKILL_KEY=novel-persona-card
SECONDME_SKILL_DISPLAY_NAME=99小说 - 你的心情写照
SECONDME_SKILL_DESCRIPTION=获取用户资料、阅读/写作画像与可分享创作信息的个人名片能力。

SESSION_SECRET=change-me-in-production
